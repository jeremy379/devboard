# Optional — default is 8765
PORT=8765


# Name shown in the browser tab and dashboard header
APP_NAME=My Project

# Emoji used as the favicon and in the header
APP_EMOJI=🎁

# ── GitHub ────────────────────────────────────────────────────────────────────
# GitHub organisation to search open PRs in
GITHUB_ORG=my-org

# ── Jira ─────────────────────────────────────────────────────────────────────
# Base URL of your Jira instance (no trailing slash)
JIRA_BASE_URL=https://my-org.atlassian.net

# Your Jira account email
JIRA_EMAIL=you@example.com

# Jira API token — create one at:
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=your_api_token_here

